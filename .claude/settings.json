{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // \"\"'); [ -n \"$FILE\" ] && ./node_modules/.bin/prettier --write \"$FILE\" --log-level warn 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  }
}
